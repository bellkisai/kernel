{
  "$schema": "https://raw.githubusercontent.com/nicollite/tauri-config-schema/main/schema.json",
  "productName": "ShrimPK Viz",
  "identifier": "ai.bellkis.shrimpk-viz",
  "version": "0.1.0",
  "build": {
    "frontendDist": "./web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ShrimPK — Knowledge Graph",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://localhost:* ws://localhost:*; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  }
}
